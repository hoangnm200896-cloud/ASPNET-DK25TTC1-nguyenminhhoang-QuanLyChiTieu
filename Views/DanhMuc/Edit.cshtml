@model DanhMuc
@{
    ViewData["Title"] = "Sửa danh mục";
}

<h2><i class="fas fa-edit"></i> Sửa danh mục</h2>
<hr />

<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="MaDanhMuc" />

            <div class="form-group">
                <label asp-for="TenDanhMuc"></label>
                <input asp-for="TenDanhMuc" class="form-control" />
                <span asp-validation-for="TenDanhMuc" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="LoaiDanhMuc"></label>
                <select asp-for="LoaiDanhMuc" class="form-control">
                    <option value="ThuNhap">Thu nhập</option>
                    <option value="ChiTieu">Chi tiêu</option>
                </select>
                <span asp-validation-for="LoaiDanhMuc" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="MoTa"></label>
                <textarea asp-for="MoTa" class="form-control" rows="3"></textarea>
                <span asp-validation-for="MoTa" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary">
                <i class="fas fa-save"></i> Cập nhật
            </button>
            <a asp-action="Index" class="btn btn-secondary">
                <i class="fas fa-arrow-left"></i> Quay lại
            </a>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
