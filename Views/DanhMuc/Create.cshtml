@model DanhMuc
@{
    ViewData["Title"] = "Thêm danh mục";
}

<h2><i class="fas fa-plus"></i> Thêm danh mục mới</h2>
<hr />

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group">
                <label asp-for="TenDanhMuc"></label>
                <input asp-for="TenDanhMuc" class="form-control" placeholder="Nhập tên danh mục" />
                <span asp-validation-for="TenDanhMuc" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="LoaiDanhMuc"></label>
                <select asp-for="LoaiDanhMuc" class="form-control">
                    <option value="">-- Chọn loại --</option>
                    <option value="ThuNhap">Thu nhập</option>
                    <option value="ChiTieu">Chi tiêu</option>
                </select>
                <span asp-validation-for="LoaiDanhMuc" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="MoTa"></label>
                <textarea asp-for="MoTa" class="form-control" rows="3" placeholder="Nhập mô tả (tùy chọn)"></textarea>
                <span asp-validation-for="MoTa" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary">
                <i class="fas fa-save"></i> Lưu
            </button>
            <a asp-action="Index" class="btn btn-secondary">
                <i class="fas fa-arrow-left"></i> Quay lại
            </a>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
