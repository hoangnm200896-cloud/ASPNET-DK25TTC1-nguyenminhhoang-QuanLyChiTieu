@model DanhMuc
@{
    ViewData["Title"] = "Xóa danh mục";
}

<h2><i class="fas fa-trash"></i> Xóa danh mục</h2>
<hr />

<div class="alert alert-warning">
    <i class="fas fa-exclamation-triangle"></i> Bạn có chắc chắn muốn xóa danh mục này?
</div>

<div class="card" style="max-width: 500px;">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-4">Tên danh mục:</dt>
            <dd class="col-sm-8">@Model.TenDanhMuc</dd>

            <dt class="col-sm-4">Loại:</dt>
            <dd class="col-sm-8">
                <span class="badge @(Model.LoaiDanhMuc == "ThuNhap" ? "badge-success" : "badge-danger")">
                    @(Model.LoaiDanhMuc == "ThuNhap" ? "Thu nhập" : "Chi tiêu")
                </span>
            </dd>

            <dt class="col-sm-4">Mô tả:</dt>
            <dd class="col-sm-8">@(Model.MoTa ?? "Không có")</dd>
        </dl>
    </div>
</div>

<form asp-action="Delete" method="post" class="mt-3">
    <input type="hidden" asp-for="MaDanhMuc" />
    <button type="submit" class="btn btn-danger">
        <i class="fas fa-trash"></i> Xác nhận xóa
    </button>
    <a asp-action="Index" class="btn btn-secondary">
        <i class="fas fa-arrow-left"></i> Quay lại
    </a>
</form>
