@model GiaoDich
@{
    ViewData["Title"] = "Sửa giao dịch";
}

<h2><i class="fas fa-edit"></i> Sửa giao dịch</h2>
<hr />

<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="MaGiaoDich" />
            <input type="hidden" asp-for="NgayTao" />

            <div class="form-group">
                <label asp-for="TenGiaoDich"></label>
                <input asp-for="TenGiaoDich" class="form-control" />
                <span asp-validation-for="TenGiaoDich" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="SoTien"></label>
                <input asp-for="SoTien" class="form-control" type="number" min="1" />
                <span asp-validation-for="SoTien" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="NgayGiaoDich"></label>
                <input asp-for="NgayGiaoDich" class="form-control" type="date" />
                <span asp-validation-for="NgayGiaoDich" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="MaDanhMuc"></label>
                <select asp-for="MaDanhMuc" asp-items="ViewBag.DanhSachDanhMuc" class="form-control">
                    <option value="">-- Chọn danh mục --</option>
                </select>
                <span asp-validation-for="MaDanhMuc" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="GhiChu"></label>
                <textarea asp-for="GhiChu" class="form-control" rows="3"></textarea>
                <span asp-validation-for="GhiChu" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary">
                <i class="fas fa-save"></i> Cập nhật
            </button>
            <a asp-action="Index" class="btn btn-secondary">
                <i class="fas fa-arrow-left"></i> Quay lại
            </a>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
