@model GiaoDich
@{
    ViewData["Title"] = "Xóa giao dịch";
}

<h2><i class="fas fa-trash"></i> Xóa giao dịch</h2>
<hr />

<div class="alert alert-warning">
    <i class="fas fa-exclamation-triangle"></i> Bạn có chắc chắn muốn xóa giao dịch này?
</div>

<div class="card" style="max-width: 500px;">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-4">Tên giao dịch:</dt>
            <dd class="col-sm-8">@Model.TenGiaoDich</dd>

            <dt class="col-sm-4">Số tiền:</dt>
            <dd class="col-sm-8 font-weight-bold">@Model.SoTien.ToString("N0") đ</dd>

            <dt class="col-sm-4">Ngày:</dt>
            <dd class="col-sm-8">@Model.NgayGiaoDich.ToString("dd/MM/yyyy")</dd>

            <dt class="col-sm-4">Danh mục:</dt>
            <dd class="col-sm-8">@Model.DanhMuc.TenDanhMuc</dd>

            <dt class="col-sm-4">Ghi chú:</dt>
            <dd class="col-sm-8">@(Model.GhiChu ?? "Không có")</dd>
        </dl>
    </div>
</div>

<form asp-action="Delete" method="post" class="mt-3">
    <input type="hidden" asp-for="MaGiaoDich" />
    <button type="submit" class="btn btn-danger">
        <i class="fas fa-trash"></i> Xác nhận xóa
    </button>
    <a asp-action="Index" class="btn btn-secondary">
        <i class="fas fa-arrow-left"></i> Quay lại
    </a>
</form>
