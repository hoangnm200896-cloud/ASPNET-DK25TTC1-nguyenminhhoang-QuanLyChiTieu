@model DashboardViewModel
@{
    ViewData["Title"] = "Trang chủ";
}

<h2><i class="fas fa-tachometer-alt"></i> Tổng quan tháng @Model.ThangHienTai/@Model.NamHienTai</h2>
<hr />

<!-- Thẻ tổng quan -->
<div class="row">
    <div class="col-md-4">
        <div class="card text-white bg-success mb-3">
            <div class="card-body">
                <h5 class="card-title"><i class="fas fa-arrow-down"></i> Tổng thu nhập</h5>
                <h3>@Model.TongThuNhap.ToString("N0") đ</h3>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-white bg-danger mb-3">
            <div class="card-body">
                <h5 class="card-title"><i class="fas fa-arrow-up"></i> Tổng chi tiêu</h5>
                <h3>@Model.TongChiTieu.ToString("N0") đ</h3>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-white @(Model.SoDu >= 0 ? "bg-info" : "bg-warning") mb-3">
            <div class="card-body">
                <h5 class="card-title"><i class="fas fa-balance-scale"></i> Số dư</h5>
                <h3>@Model.SoDu.ToString("N0") đ</h3>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <!-- Biểu đồ tròn -->
    <div class="col-md-6">
        <div class="card mb-3">
            <div class="card-header bg-primary text-white">
                <i class="fas fa-chart-pie"></i> Chi tiêu theo danh mục
            </div>
            <div class="card-body">
                @if (Model.ChiTieuTheoDanhMuc.Any())
                {
                    <canvas id="chartDanhMuc" height="250"></canvas>
                }
                else
                {
                    <p class="text-muted text-center">Chưa có dữ liệu chi tiêu trong tháng này.</p>
                }
            </div>
        </div>
    </div>

    <!-- Giao dịch gần nhất -->
    <div class="col-md-6">
        <div class="card mb-3">
            <div class="card-header bg-primary text-white">
                <i class="fas fa-history"></i> Giao dịch gần nhất
            </div>
            <div class="card-body p-0">
                @if (Model.GiaoDichGanNhat.Any())
                {
                    <table class="table table-striped table-sm mb-0">
                        <thead>
                            <tr>
                                <th>Tên</th>
                                <th>Số tiền</th>
                                <th>Ngày</th>
                                <th>Loại</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var gd in Model.GiaoDichGanNhat)
                            {
                                <tr>
                                    <td>@gd.TenGiaoDich</td>
                                    <td class="@(gd.DanhMuc.LoaiDanhMuc == "ThuNhap" ? "text-success" : "text-danger")">
                                        @(gd.DanhMuc.LoaiDanhMuc == "ThuNhap" ? "+" : "-")@gd.SoTien.ToString("N0") đ
                                    </td>
                                    <td>@gd.NgayGiaoDich.ToString("dd/MM/yyyy")</td>
                                    <td>
                                        <span class="badge @(gd.DanhMuc.LoaiDanhMuc == "ThuNhap" ? "badge-success" : "badge-danger")">
                                            @(gd.DanhMuc.LoaiDanhMuc == "ThuNhap" ? "Thu" : "Chi")
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p class="text-muted text-center p-3">Chưa có giao dịch nào.</p>
                }
            </div>
            <div class="card-footer">
                <a asp-controller="GiaoDich" asp-action="Index" class="btn btn-sm btn-outline-primary">Xem tất cả</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        @if (Model.ChiTieuTheoDanhMuc.Any())
        {
            <text>
            var ctx = document.getElementById('chartDanhMuc').getContext('2d');
            var chart = new Chart(ctx, {
                type: 'pie',
                data: {
                    labels: [@Html.Raw(string.Join(",", Model.ChiTieuTheoDanhMuc.Keys.Select(k => "'" + k + "'")))],
                    datasets: [{
                        data: [@Html.Raw(string.Join(",", Model.ChiTieuTheoDanhMuc.Values))],
                        backgroundColor: [
                            '#FF6384', '#36A2EB', '#FFCE56', '#4BC0C0',
                            '#9966FF', '#FF9F40', '#FF6384', '#C9CBCF',
                            '#7BC225', '#E7E9ED'
                        ]
                    }]
                },
                options: {
                    responsive: true,
                    legend: {
                        position: 'bottom'
                    }
                }
            });
            </text>
        }
    </script>
}
