@model ThongKeViewModel
@{
    ViewData["Title"] = "Thống kê";
}

<h2><i class="fas fa-chart-bar"></i> Báo cáo thống kê</h2>
<hr />

<!-- Form chọn tháng/năm -->
<form method="get" asp-action="Index" class="form-inline mb-3">
    <label class="mr-2">Tháng:</label>
    <select name="thang" class="form-control mr-2">
        @for (int i = 1; i <= 12; i++)
        {
            if (Model.Thang == i)
            {
                @:<option value="@i" selected>Tháng @i</option>
            }
            else
            {
                @:<option value="@i">Tháng @i</option>
            }
        }
    </select>
    <label class="mr-2">Năm:</label>
    <select name="nam" class="form-control mr-2">
        @for (int i = DateTime.Now.Year - 5; i <= DateTime.Now.Year + 1; i++)
        {
            if (Model.Nam == i)
            {
                @:<option value="@i" selected>@i</option>
            }
            else
            {
                @:<option value="@i">@i</option>
            }
        }
    </select>
    <button type="submit" class="btn btn-primary">
        <i class="fas fa-filter"></i> Xem thống kê
    </button>
</form>

<!-- Tổng quan -->
<div class="row mb-3">
    <div class="col-md-4">
        <div class="card text-white bg-success">
            <div class="card-body text-center">
                <h6>Tổng thu nhập</h6>
                <h4>@Model.TongThuNhap.ToString("N0") đ</h4>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-white bg-danger">
            <div class="card-body text-center">
                <h6>Tổng chi tiêu</h6>
                <h4>@Model.TongChiTieu.ToString("N0") đ</h4>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-white @(Model.SoDu >= 0 ? "bg-info" : "bg-warning")">
            <div class="card-body text-center">
                <h6>Số dư</h6>
                <h4>@Model.SoDu.ToString("N0") đ</h4>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <!-- Biểu đồ cột thu chi theo tháng -->
    <div class="col-md-8">
        <div class="card mb-3">
            <div class="card-header bg-primary text-white">
                <i class="fas fa-chart-bar"></i> Thu chi theo từng tháng năm @Model.Nam
            </div>
            <div class="card-body">
                <canvas id="chartThang" height="300"></canvas>
            </div>
        </div>
    </div>

    <!-- Biểu đồ tròn chi tiêu theo danh mục -->
    <div class="col-md-4">
        <div class="card mb-3">
            <div class="card-header bg-primary text-white">
                <i class="fas fa-chart-pie"></i> Chi tiêu tháng @Model.Thang
            </div>
            <div class="card-body">
                @if (Model.ChiTieuTheoDanhMuc.Any())
                {
                    <canvas id="chartDanhMuc" height="300"></canvas>
                }
                else
                {
                    <p class="text-muted text-center">Không có dữ liệu</p>
                }
            </div>
        </div>
    </div>
</div>

<!-- Bảng chi tiết giao dịch trong tháng -->
<div class="card mb-3">
    <div class="card-header bg-primary text-white">
        <i class="fas fa-table"></i> Chi tiết giao dịch tháng @Model.Thang/@Model.Nam
    </div>
    <div class="card-body p-0">
        <table class="table table-bordered table-striped mb-0">
            <thead class="thead-light">
                <tr>
                    <th>STT</th>
                    <th>Tên giao dịch</th>
                    <th>Số tiền</th>
                    <th>Ngày</th>
                    <th>Danh mục</th>
                    <th>Loại</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.DanhSachGiaoDich.Any())
                {
                    int stt = 1;
                    @foreach (var gd in Model.DanhSachGiaoDich)
                    {
                        <tr>
                            <td>@(stt++)</td>
                            <td>@gd.TenGiaoDich</td>
                            <td class="@(gd.DanhMuc.LoaiDanhMuc == "ThuNhap" ? "text-success" : "text-danger") font-weight-bold">
                                @(gd.DanhMuc.LoaiDanhMuc == "ThuNhap" ? "+" : "-")@gd.SoTien.ToString("N0") đ
                            </td>
                            <td>@gd.NgayGiaoDich.ToString("dd/MM/yyyy")</td>
                            <td>@gd.DanhMuc.TenDanhMuc</td>
                            <td>
                                <span class="badge @(gd.DanhMuc.LoaiDanhMuc == "ThuNhap" ? "badge-success" : "badge-danger")">
                                    @(gd.DanhMuc.LoaiDanhMuc == "ThuNhap" ? "Thu" : "Chi")
                                </span>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted">Không có giao dịch trong tháng này.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        // Biểu đồ cột thu chi theo tháng
        var ctxThang = document.getElementById('chartThang').getContext('2d');
        var chartThang = new Chart(ctxThang, {
            type: 'bar',
            data: {
                labels: ['T1', 'T2', 'T3', 'T4', 'T5', 'T6', 'T7', 'T8', 'T9', 'T10', 'T11', 'T12'],
                datasets: [
                    {
                        label: 'Thu nhập',
                        data: [@Html.Raw(string.Join(",", Model.ThuNhapTheoThang))],
                        backgroundColor: 'rgba(40, 167, 69, 0.7)',
                        borderColor: 'rgba(40, 167, 69, 1)',
                        borderWidth: 1
                    },
                    {
                        label: 'Chi tiêu',
                        data: [@Html.Raw(string.Join(",", Model.ChiTieuTheoThang))],
                        backgroundColor: 'rgba(220, 53, 69, 0.7)',
                        borderColor: 'rgba(220, 53, 69, 1)',
                        borderWidth: 1
                    }
                ]
            },
            options: {
                responsive: true,
                scales: {
                    yAxes: [{
                        ticks: {
                            beginAtZero: true,
                            callback: function(value) {
                                return value.toLocaleString('vi-VN') + ' đ';
                            }
                        }
                    }]
                },
                tooltips: {
                    callbacks: {
                        label: function(tooltipItem, data) {
                            return data.datasets[tooltipItem.datasetIndex].label + ': ' +
                                   tooltipItem.yLabel.toLocaleString('vi-VN') + ' đ';
                        }
                    }
                }
            }
        });

        // Biểu đồ tròn chi tiêu theo danh mục
        @if (Model.ChiTieuTheoDanhMuc.Any())
        {
            <text>
            var ctxDM = document.getElementById('chartDanhMuc').getContext('2d');
            var chartDM = new Chart(ctxDM, {
                type: 'pie',
                data: {
                    labels: [@Html.Raw(string.Join(",", Model.ChiTieuTheoDanhMuc.Keys.Select(k => "'" + k + "'")))],
                    datasets: [{
                        data: [@Html.Raw(string.Join(",", Model.ChiTieuTheoDanhMuc.Values))],
                        backgroundColor: [
                            '#FF6384', '#36A2EB', '#FFCE56', '#4BC0C0',
                            '#9966FF', '#FF9F40', '#FF6384', '#C9CBCF',
                            '#7BC225', '#E7E9ED'
                        ]
                    }]
                },
                options: {
                    responsive: true,
                    legend: {
                        position: 'bottom',
                        labels: {
                            fontSize: 11
                        }
                    },
                    tooltips: {
                        callbacks: {
                            label: function(tooltipItem, data) {
                                var label = data.labels[tooltipItem.index];
                                var value = data.datasets[0].data[tooltipItem.index];
                                return label + ': ' + value.toLocaleString('vi-VN') + ' đ';
                            }
                        }
                    }
                }
            });
            </text>
        }
    </script>
}
